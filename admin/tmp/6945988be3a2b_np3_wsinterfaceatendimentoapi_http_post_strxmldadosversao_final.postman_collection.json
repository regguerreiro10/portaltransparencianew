		{
			"name": "05 - API_RecuperarFatura (Faturas)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// -------- decode SOAP <string> and visualize faturas --------",
							"const raw = pm.response.text();",
							"",
							"function htmlDecode(s) {",
							"  return s",
							"    .replace(/&lt;/g, \"<\")",
							"    .replace(/&gt;/g, \">\")",
							"    .replace(/&amp;/g, \"&\")",
							"    .replace(/&quot;/g, \"\\\"\")",
							"    .replace(/&#39;/g, \"'\")",
							"    .replace(/&apos;/g, \"'\");",
							"}",
							"",
							"function stripCdata(s) {",
							"  if (!s) return \"\";",
							"  return s.replace(/^<!\\[CDATA\\[/, \"\").replace(/\\]\\]>$/, \"\");",
							"}",
							"",
							"function getTag(xml, tag) {",
							"  const re = new RegExp(`<${tag}[^>]*>\\\\s*([\\\\s\\\\S]*?)\\\\s*<\\\\/${tag}>`, \"i\");",
							"  const m = xml.match(re);",
							"  return m && m[1] ? stripCdata(m[1].trim()) : \"\";",
							"}",
							"",
							"function getAllFaturas(xml) {",
							"  const list = [];",
							"  const block = (xml.match(/<faturas[^>]*>([\\s\\S]*?)<\\/faturas>/i) || [])[1] || \"\";",
							"  const re = /<fatura[^>]*>([\\s\\S]*?)<\\/fatura>/gi;",
							"  let m;",
							"  while ((m = re.exec(block)) !== null) {",
							"    const f = m[1];",
							"    list.push({",
							"      nu_seq_fatura: getTag(f, \"nu_seq_fatura\"),",
							"      tp_fase_fatura: getTag(f, \"tp_fase_fatura\"),",
							"      dt_venc_fatura: getTag(f, \"dt_venc_fatura\"),",
							"      vl_saldo_fatura: getTag(f, \"vl_saldo_fatura\"),",
							"      vl_pagto_minimo: getTag(f, \"vl_pagto_minimo\"),",
							"      nu_linha_digitavel: getTag(f, \"nu_linha_digitavel\"),",
							"      de_qrcode_pix: getTag(f, \"de_qrcode_pix\"),",
							"      de_url_fatura: getTag(f, \"de_url_fatura\")",
							"    });",
							"  }",
							"  return list;",
							"}",
							"",
							"// Extract inner XML (SOAP <string>escaped</string> OR plain XML)",
							"let xml = raw;",
							"const sm = raw.match(/<string[^>]*>([\\s\\S]*?)<\\/string>/i);",
							"if (sm && sm[1]) xml = htmlDecode(sm[1]);",
							"xml = xml.trim();",
							"",
							"// Save cd_rede/cd_cliente if returned",
							"const cod = getTag(xml, \"cod\");",
							"const msg = getTag(xml, \"msg\");",
							"const cd_rede = getTag(xml, \"cd_rede\");",
							"const cd_cliente = getTag(xml, \"cd_cliente\");",
							"if (cd_rede) pm.collectionVariables.set(\"cd_rede\", cd_rede);",
							"if (cd_cliente) pm.collectionVariables.set(\"cd_cliente\", cd_cliente);",
							"",
							"const faturas = getAllFaturas(xml);",
							"",
							"const vm = {",
							"  status: { cod, msg, cd_rede, cd_cliente },",
							"  faturas,",
							"  rawXml: xml",
							"};",
							"",
							"const template = `",
							"<style>",
							"  body{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Arial,sans-serif;padding:12px}",
							"  .card{border:1px solid #3333;border-radius:10px;padding:12px;margin-bottom:12px}",
							"  .ok{color:#2e7d32;font-weight:700}",
							"  .bad{color:#c62828;font-weight:700}",
							"  table{width:100%;border-collapse:collapse;font-size:13px}",
							"  th,td{border-bottom:1px solid #3333;padding:8px;vertical-align:top}",
							"  th{opacity:.8;text-align:left}",
							"  pre{white-space:pre-wrap;word-break:break-word;font-size:12px;border:1px solid #3333;padding:10px;border-radius:10px}",
							"</style>",
							"",
							"<div class='card'>",
							"  <div>Status: <span class='{{statusClass}}'>{{status.cod}}</span> — {{status.msg}}</div>",
							"  <div>cd_rede: <b>{{status.cd_rede}}</b> | cd_cliente: <b>{{status.cd_cliente}}</b></div>",
							"</div>",
							"",
							"<div class='card'>",
							"  <h3 style='margin:0 0 10px 0'>Faturas ({{faturas.length}})</h3>",
							"  <table>",
							"    <thead>",
							"      <tr>",
							"        <th>Seq</th><th>Fase</th><th>Vencimento</th><th>Valor</th><th>Min.</th><th>Linha digitável</th><th>Pix</th><th>URL PDF</th>",
							"      </tr>",
							"    </thead>",
							"    <tbody>",
							"    {{#each faturas}}",
							"      <tr>",
							"        <td>{{nu_seq_fatura}}</td>",
							"        <td>{{tp_fase_fatura}}</td>",
							"        <td>{{dt_venc_fatura}}</td>",
							"        <td>{{vl_saldo_fatura}}</td>",
							"        <td>{{vl_pagto_minimo}}</td>",
							"        <td style='word-break:break-word'>{{nu_linha_digitavel}}</td>",
							"        <td style='word-break:break-word'>{{de_qrcode_pix}}</td>",
							"        <td style='word-break:break-word'>{{de_url_fatura}}</td>",
							"      </tr>",
							"    {{/each}}",
							"    </tbody>",
							"  </table>",
							"</div>",
							"",
							"<div class='card'>",
							"  <h3 style='margin:0 0 10px 0'>XML bruto (decodificado)</h3>",
							"  <pre>{{rawXml}}</pre>",
							"</div>",
							"`;",
							"",
							"vm.statusClass = (cod === \"0\") ? \"ok\" : \"bad\";",
							"pm.visualizer.set(template, vm);"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
