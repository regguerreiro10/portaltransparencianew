		{
			"name": "02 - API_Login (identificacao_cliente / nu_cartao + de_senha + de_token)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const raw = pm.response.text();",
							"",
							"function htmlDecode(s) {",
							"  return s",
							"    .replace(/&lt;/g, \"<\")",
							"    .replace(/&gt;/g, \">\")",
							"    .replace(/&amp;/g, \"&\")",
							"    .replace(/&quot;/g, \"\\\"\")",
							"    .replace(/&#39;/g, \"'\")",
							"    .replace(/&apos;/g, \"'\");",
							"}",
							"",
							"const sm = raw.match(/<string[^>]*>([\\s\\S]*?)<\\/string>/i);",
							"const inner = sm && sm[1] ? htmlDecode(sm[1]) : raw;",
							"",
							"// pega erro",
							"const cod = (inner.match(/<cod>\\s*([^<]+)\\s*<\\/cod>/i)||[])[1];",
							"const msg = (inner.match(/<msg>\\s*([^<]+)\\s*<\\/msg>/i)||[])[1];",
							"console.log(\"cod:\", cod, \"msg:\", msg);",
							"",
							"// salva cd_rede e cd_cliente se vierem",
							"const cd_rede = (inner.match(/<cd_rede>\\s*([^<]*)\\s*<\\/cd_rede>/i)||[])[1];",
							"const cd_cliente = (inner.match(/<cd_cliente>\\s*([^<]*)\\s*<\\/cd_cliente>/i)||[])[1];",
							"",
							"if (cd_rede) pm.collectionVariables.set(\"cd_rede\", cd_rede.trim());",
							"if (cd_cliente) pm.collectionVariables.set(\"cd_cliente\", cd_cliente.trim());",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
