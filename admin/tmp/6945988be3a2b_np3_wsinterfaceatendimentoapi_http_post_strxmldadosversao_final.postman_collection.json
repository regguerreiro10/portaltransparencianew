		{
			"name": "01 - API_PegarTokenJwt",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// 1) Read raw response (SOAP)",
							"const raw = pm.response.text();",
							"",
							"// Helper: decode HTML entities (&lt; &gt; &amp; etc)",
							"function htmlDecode(s) {",
							"  return s",
							"    .replace(/&lt;/g, \"<\")",
							"    .replace(/&gt;/g, \">\")",
							"    .replace(/&amp;/g, \"&\")",
							"    .replace(/&quot;/g, \"\\\"\")",
							"    .replace(/&#39;/g, \"'\")",
							"    .replace(/&apos;/g, \"'\");",
							"}",
							"",
							"// 2) Try direct <de_token> first (some servers return plain XML)",
							"let token = null;",
							"let m = raw.match(/<de_token>\\s*(?:<!\\[CDATA\\[)?([\\s\\S]*?)(?:\\]\\]>)?\\s*<\\/de_token>/i);",
							"if (m && m[1]) token = m[1].trim();",
							"",
							"// 3) If not found, extract inner escaped XML inside <string>...</string>",
							"if (!token) {",
							"  const sm = raw.match(/<string[^>]*>([\\s\\S]*?)<\\/string>/i);",
							"  if (sm && sm[1]) {",
							"    const innerXml = htmlDecode(sm[1]);",
							"",
							"    const tm = innerXml.match(/<de_token>\\s*(?:<!\\[CDATA\\[)?([\\s\\S]*?)(?:\\]\\]>)?\\s*<\\/de_token>/i);",
							"    if (tm && tm[1]) token = tm[1].trim();",
							"  }",
							"}",
							"",
							"// 4) Save to collection variable",
							"if (token) {",
							"  pm.collectionVariables.set(\"app_token\", token);",
							"  console.log(\"✅ app_token salvo. len =\", token.length);",
							"  console.log(\"Lido da variável:\", pm.collectionVariables.get(\"app_token\"));",
							"",
							"} else {",
							"  console.warn(\"❌ Não achei de_token. Raw response:\", raw);",
							"}",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/x-www-form-urlencoded"
					}
				],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{
							"key": "strXMLDados",
							"value": "<atend>\n  <identificacao_origem>\n    <cd_grupo>{{cd_grupo}}</cd_grupo>\n    <de_login_usu>{{origem_login}}</de_login_usu>\n    <de_senha_usu>{{origem_senha}}</de_senha_usu>\n  </identificacao_origem>\n</atend>",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/API_PegarTokenJwt",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"API_PegarTokenJwt"
					]
				}
			},
			"response": []
